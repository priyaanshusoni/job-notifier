// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
    output   = "../src/generated/prisma"
  
}

datasource db {
  provider = "postgresql"
}


model Preference {
  id         Int      @id @default(autoincrement())
  roles      String[]  // "Full Stack Developer, React Developer"
  skills     String[]   // "Next.js, TypeScript, Node.js"
  location   String[]  // "Jaipur, Remote"
  minSalary  Int      // 800000
  experience String   // "1-3 years"
  metaInfo   String   // meta info about company 
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
 
}

model SeenJob {
  id       String   @id   // job ID from API
  source   String         // "LinkedIn", "Naukri" etc
  seenAt   DateTime @default(now())
 
}